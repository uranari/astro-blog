---
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'posts'>;
}

const { entry } = Astro.props;
const { data, slug } = entry;
const ogPath = `/og/${slug}.png`;
---

<BaseLayout
  title={data.title}
  description={data.description}
  ogImage={ogPath}
  type="article"
  publishedTime={data.pubDate}
  tags={data.tags}
>
  <article class="prose">
    <header class="post-header">
      {data.category && <p class="post-header__category">{data.category}</p>}
      <h1 class="post-header__title">{data.title}</h1>
      <div class="post-header__meta">
        <FormattedDate date={data.pubDate} />
        {data.updatedDate && (
          <span>(updated <FormattedDate date={data.updatedDate} />)</span>
        )}
        {data.tags.length > 0 && (
          <ul class="tag-list">
            {data.tags.map((tag) => (
              <li><a class="tag" href={`/tags/${tag}/`}>{tag}</a></li>
            ))}
          </ul>
        )}
      </div>
      {data.heroImage && (
        <div class="post-header__hero">
          <Image
            src={data.heroImage}
            alt={data.heroImageAlt ?? ''}
            widths={[400, 800, 1200]}
            sizes="(max-width: 800px) 100vw, 800px"
            loading="eager"
          />
        </div>
      )}
    </header>

    <slot />
  </article>
</BaseLayout>
